# ---- Frontend production env ----
# Set these in Netlify: Site configuration → Environment variables.
# NEXT_PUBLIC_* values are inlined at BUILD time, so changing one requires a
# redeploy — editing it in the Netlify UI alone has no effect on a built site.

# Public HTTPS URL of the Lumora API (the Render service)
NEXT_PUBLIC_API_URL=https://lumora-api.onrender.com

# Public HTTPS URL of this web app (the Netlify site)
NEXT_PUBLIC_SITE_URL=https://lumora.netlify.app
