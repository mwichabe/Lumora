# ---- Lumora API configuration (copy to .env; NEVER commit real secrets) ----
PORT=8080
# Use a long, random secret in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
# Postgres connection string. When set it WINS and the app uses Postgres — this
# is what production (Render) uses. Leave empty locally to use the SQLite file
# at DB_PATH, so dev needs no database server.
#   e.g. postgres://user:pass@host.neon.tech/lumora?sslmode=require
DATABASE_URL=
DB_PATH=lumora.db
# Comma-separated list of allowed web origins (your frontend URL in prod)
CORS_ORIGINS=http://localhost:3000

# Public URL of the web app (used in emails and the Paystack callback)
APP_URL=http://localhost:3000

# Email (welcome / sign-in / receipts / password reset) via SMTP.
# For Gmail use an App Password (2FA required). SMTP_FROM must be the
# authenticated address. Leave SMTP_HOST empty to disable email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com
SMTP_FROM_NAME=Lumora
# LOGO_URL=https://your-domain.com/logo.svg

# Paystack. Use LIVE keys (sk_live_ / pk_live_) in production. Empty = payments
# disabled and exams stay free.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Approx KES per 1 USD (display-only USD equivalent for international users)
KES_PER_USD=130

# Hearts economy: minutes for ONE heart to regenerate (max 3/5 per code).
HEART_REGEN_MINUTES=30

# Message translation (chat + idea threads). Language DETECTION is offline and
# always on — it costs nothing and labels every message. Only the translation
# itself calls the Claude API, and only for messages detected as non-English.
# Leave the key empty to keep detection and skip translation entirely.
ANTHROPIC_API_KEY=
TRANSLATE_MODEL=claude-opus-4-8
